pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
                checkout scm
            }
        }
        
        stage('Restore ConsoleApp1') {
            steps {
                echo 'Restoring ConsoleApp1 packages...'
                dir('TEST/ConsoleApp1') {
                    sh 'dotnet restore'
                }
            }
        }
        
        stage('Restore Tests') {
            steps {
                echo 'Restoring Test packages...'
                dir('TEST/SimpleApp.Tests') {
                    sh 'dotnet restore'
                }
            }
        }
        
        stage('Build ConsoleApp1') {
            steps {
                echo 'Building ConsoleApp1...'
                dir('TEST/ConsoleApp1') {
                    sh 'dotnet build --configuration Release --no-restore'
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                echo 'Running tests...'
                dir('TEST/SimpleApp.Tests') {
                    sh 'dotnet test --configuration Release --no-restore --verbosity normal'
                }
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline finished!'
        }
        success {
            echo '✅ All tests passed!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
    }
}